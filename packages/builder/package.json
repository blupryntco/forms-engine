{
    "name": "@bluprynt/forms-builder",
    "version": "0.0.0",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "biome check .",
        "check-types": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "peerDependencies": {
        "@bluprynt/forms-core": "workspace:*",
        "react": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@bluprynt/forms-core": "workspace:*",
        "@repo/typescript-config": "workspace:*",
        "@testing-library/react": "16.3.2",
        "@types/jest": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "19.1.6",
        "jest": "catalog:",
        "jest-environment-jsdom": "30.3.0",
        "react": "catalog:",
        "react-dom": "19.1.0",
        "ts-jest": "catalog:",
        "tsdown": "catalog:",
        "typescript": "catalog:"
    },
    "dependencies": {
        "@dnd-kit/abstract": "0.3.2",
        "@dnd-kit/dom": "0.3.2",
        "@dnd-kit/helpers": "0.3.2",
        "@dnd-kit/react": "0.3.2",
        "@dnd-kit/state": "0.3.2"
    }
}
