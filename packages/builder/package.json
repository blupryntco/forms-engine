{
    "name": "@bluprynt/forms-builder",
    "version": "2.0.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/blupryntco/forms-engine.git",
        "directory": "packages/builder"
    },
    "homepage": "https://blupryntco.github.io/forms-engine/",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "biome check .",
        "check-types": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "peerDependencies": {
        "@bluprynt/forms-core": "workspace:*",
        "@dnd-kit/abstract": "^0.3.0",
        "@dnd-kit/dom": "^0.3.0",
        "@dnd-kit/helpers": "^0.3.0",
        "@dnd-kit/react": "^0.3.0",
        "@dnd-kit/state": "^0.3.0",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@bluprynt/forms-core": "workspace:*",
        "@dnd-kit/abstract": "catalog:",
        "@dnd-kit/dom": "catalog:",
        "@dnd-kit/helpers": "catalog:",
        "@dnd-kit/react": "catalog:",
        "@dnd-kit/state": "catalog:",
        "@repo/typescript-config": "workspace:*",
        "@testing-library/react": "catalog:",
        "@types/jest": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "jest": "catalog:",
        "jest-environment-jsdom": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "ts-jest": "catalog:",
        "tsdown": "catalog:",
        "typescript": "catalog:"
    }
}
