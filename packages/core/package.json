{
    "name": "@bluprynt/forms-core",
    "version": "2.0.0",
    "private": false,
    "repository": {
        "type": "git",
        "url": "https://github.com/blupryntco/forms-engine.git",
        "directory": "packages/core"
    },
    "homepage": "https://blupryntco.github.io/forms-engine/",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        },
        "./schemas/form-definition.schema.json": "./dist/form-definition.schema.json"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown && cp src/*.schema.json dist/",
        "dev": "tsdown --watch",
        "lint": "biome check .",
        "check-types": "tsc --noEmit",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage"
    },
    "peerDependencies": {
        "ajv": "^8.0.0"
    },
    "devDependencies": {
        "@repo/typescript-config": "workspace:*",
        "@types/jest": "catalog:",
        "ajv": "catalog:",
        "jest": "catalog:",
        "ts-jest": "catalog:",
        "tsdown": "catalog:",
        "typescript": "catalog:"
    }
}
