{
    "$schema": "https://unpkg.com/knip@5/schema.json",
    "ignore": ["wip/**"],
    "workspaces": {
        "packages/typescript-config": {
            "entry": [],
            "project": []
        },
        "packages/*": {
            "project": ["src/**/*.ts"]
        },
        "packages/react": {
            "project": ["src/**/*.ts"],
            "ignoreDependencies": ["react", "@types/react", "@bluprynt/forms-core"]
        }
    }
}
